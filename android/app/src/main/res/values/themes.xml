<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <!--
        Base application theme — XML shell only.

        Motion Mouse is dark-only and themes itself fully via Compose
        (see ui/theme/Theme.kt — MotionMouseTheme / MaterialTheme).

        This XML theme exists only because Android requires a theme
        declared in AndroidManifest.xml that applies *before* Compose
        has a chance to draw anything — it controls the window
        background, status bar colour, and navigation bar colour
        during the brief moment between process start and the first
        Compose frame being drawn. After that, Compose's MaterialTheme
        takes over for everything visual inside the app.

        Colours below are pulled directly from ui/theme/Color.kt so the
        native window matches the Compose UI with no visible flash/seam.
    -->
    <style name="Theme.MotionMouse" parent="android:Theme.Material.NoActionBar">
        <!-- Surface0 (#0A0A0F) — matches Compose's dark background exactly -->
        <item name="android:windowBackground">#0A0A0F</item>
        <item name="android:statusBarColor">#0A0A0F</item>
        <item name="android:navigationBarColor">#0A0A0F</item>

        <!-- Light icons/text on our dark status & nav bars -->
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar" tools:targetApi="o_mr1">false</item>
    </style>

</resources>
