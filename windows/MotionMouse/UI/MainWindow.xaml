<Window
    x:Class="MotionMouse.UI.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="clr-namespace:MotionMouse.UI.ViewModels"
    mc:Ignorable="d"
    Style="{StaticResource MotionMouseWindow}"
    Title="Motion Mouse"
    Width="380"
    Height="520"
    WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <!--
            Converters used for data binding transformations.
            Defined locally so they are scoped to this window only.
        -->
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <!--
        Root grid — full window background.
        Single column, rows for each logical section.
    -->
    <Grid Background="{StaticResource Surface0Brush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- Title bar -->
            <RowDefinition Height="Auto"/>   <!-- Connection status card -->
            <RowDefinition Height="Auto"/>   <!-- Device info card -->
            <RowDefinition Height="Auto"/>   <!-- Motion status card -->
            <RowDefinition Height="*"/>      <!-- Spacer -->
            <RowDefinition Height="Auto"/>   <!-- Bottom action bar -->
        </Grid.RowDefinitions>

        <!-- TITLE BAR
             Custom title bar — draggable, shows app name and settings button. -->
        <Grid
            Grid.Row="0"
            Background="{StaticResource Surface0Brush}"
            MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- App name -->
            <StackPanel
                Grid.Column="0"
                Orientation="Horizontal"
                Margin="20,16,0,16">
                <Ellipse
                    Width="8" Height="8"
                    Margin="0,0,8,0"
                    x:Name="StatusDot"
                    Fill="{StaticResource DisconnectedBrush}"/>
                <TextBlock
                    Text="Motion Mouse"
                    FontSize="15"
                    FontWeight="SemiBold"
                    Foreground="{StaticResource TextPrimaryBrush}"/>
            </StackPanel>

            <!-- Settings button -->
            <Button
                Grid.Column="1"
                Style="{StaticResource GhostButton}"
                Content="⚙"
                FontSize="14"
                Margin="0,0,12,0"
                Padding="8,4"
                Command="{Binding OpenSettingsCommand}"
                ToolTip="Settings"/>
        </Grid>

        <!-- Thin separator -->
        <Rectangle
            Grid.Row="0"
            Height="1"
            VerticalAlignment="Bottom"
            Fill="{StaticResource Surface2Brush}"/>

        <!-- CONNECTION STATUS CARD
             Shows whether we are listening, connected, or idle. -->
        <Border Grid.Row="1" Style="{StaticResource Card}" Margin="16,16,16,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">

                    <!-- Section label -->
                    <TextBlock
                        Text="CONNECTION"
                        Style="{StaticResource SectionHeader}"/>

                    <!-- Primary status text — large, prominent -->
                    <TextBlock
                        x:Name="StatusText"
                        Text="{Binding StatusText}"
                        FontSize="22"
                        FontWeight="Light"
                        Foreground="{StaticResource TextPrimaryBrush}"
                        Margin="0,0,0,4"/>

                    <!-- Sub-status — transport type or searching message -->
                    <TextBlock
                        Text="{Binding SubStatusText}"
                        Style="{StaticResource SecondaryText}"
                        Margin="0,0,0,0"/>
                </StackPanel>

                <!-- Connection type badge — shown when connected -->
                <Border
                    Grid.Column="1"
                    Background="{StaticResource Surface3Brush}"
                    CornerRadius="100"
                    Padding="10,4"
                    VerticalAlignment="Center"
                    Visibility="{Binding IsConnected, Converter={StaticResource BoolToVis}}">
                    <TextBlock
                        Text="{Binding ConnectionTypeName}"
                        FontSize="11"
                        FontWeight="Medium"
                        Foreground="{StaticResource MotionBlueBrush}"/>
                </Border>
            </Grid>
        </Border>

        <!-- DEVICE INFO CARD
             Shown only when connected.
             Displays phone name, battery, and latency. -->
        <Border
            Grid.Row="2"
            Style="{StaticResource Card}"
            Margin="16,8,16,0"
            Visibility="{Binding IsConnected, Converter={StaticResource BoolToVis}}">

            <StackPanel>
                <TextBlock
                    Text="DEVICE"
                    Style="{StaticResource SectionHeader}"/>

                <!-- Phone name -->
                <TextBlock
                    Text="{Binding DeviceName}"
                    FontSize="18"
                    FontWeight="Medium"
                    Foreground="{StaticResource TextPrimaryBrush}"
                    Margin="0,0,0,12"
                    TextTrimming="CharacterEllipsis"/>

                <!-- Battery + Latency row -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Battery -->
                    <StackPanel Grid.Column="0">
                        <TextBlock
                            Text="BATTERY"
                            Style="{StaticResource SectionHeader}"
                            Margin="0,0,0,2"/>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock
                                Text="{Binding BatteryLevel, StringFormat={}{0}%}"
                                FontSize="20"
                                FontWeight="Light"
                                Foreground="{StaticResource TextPrimaryBrush}"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Latency -->
                    <StackPanel Grid.Column="1">
                        <TextBlock
                            Text="LATENCY"
                            Style="{StaticResource SectionHeader}"
                            Margin="0,0,0,2"/>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock
                                Text="{Binding LatencyMs}"
                                FontSize="20"
                                FontWeight="Light"
                                Foreground="{StaticResource TextPrimaryBrush}"/>
                            <TextBlock
                                Text="ms"
                                FontSize="13"
                                Foreground="{StaticResource TextSecondaryBrush}"
                                VerticalAlignment="Bottom"
                                Margin="3,0,0,2"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Border>

        <!-- MOTION STATUS CARD
             Shows whether motion is active or locked.
             Shown only when connected. -->
        <Border
            Grid.Row="3"
            Style="{StaticResource Card}"
            Margin="16,8,16,0"
            Visibility="{Binding IsConnected, Converter={StaticResource BoolToVis}}">

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock
                        Text="MOTION"
                        Style="{StaticResource SectionHeader}"/>
                    <TextBlock
                        Text="{Binding MotionStatusText}"
                        FontSize="16"
                        FontWeight="Medium"
                        Foreground="{StaticResource TextPrimaryBrush}"/>
                </StackPanel>

                <!-- Lock indicator pill -->
                <Border
                    Grid.Column="1"
                    CornerRadius="100"
                    Padding="10,4"
                    VerticalAlignment="Center"
                    Background="{Binding LockIndicatorBackground}">
                    <TextBlock
                        Text="{Binding LockStatusText}"
                        FontSize="11"
                        FontWeight="Medium"
                        Foreground="{Binding LockIndicatorForeground}"/>
                </Border>
            </Grid>
        </Border>

        <!-- SEARCHING PLACEHOLDER
             Shown when not connected — animated searching state. -->
        <StackPanel
            Grid.Row="2"
            Grid.RowSpan="2"
            VerticalAlignment="Center"
            HorizontalAlignment="Center"
            Margin="40,20"
            Visibility="{Binding IsDisconnected, Converter={StaticResource BoolToVis}}">

            <!-- Animated pulse ring -->
            <Grid
                Width="72" Height="72"
                HorizontalAlignment="Center"
                Margin="0,0,0,20">
                <Ellipse
                    x:Name="PulseRing"
                    Width="72" Height="72"
                    Stroke="{StaticResource MotionBlueBrush}"
                    StrokeThickness="1.5"
                    Opacity="0">
                    <Ellipse.RenderTransform>
                        <ScaleTransform
                            x:Name="PulseScale"
                            CenterX="36" CenterY="36"/>
                    </Ellipse.RenderTransform>
                </Ellipse>
                <Ellipse
                    Width="40" Height="40"
                    Fill="{StaticResource Surface2Brush}"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"/>
                <TextBlock
                    Text="⊙"
                    FontSize="18"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Foreground="{StaticResource MotionBlueBrush}"/>
            </Grid>

            <TextBlock
                Text="{Binding StatusText}"
                FontSize="18"
                FontWeight="Light"
                Foreground="{StaticResource TextPrimaryBrush}"
                HorizontalAlignment="Center"
                Margin="0,0,0,8"/>

            <TextBlock
                Text="{Binding SubStatusText}"
                Style="{StaticResource SecondaryText}"
                HorizontalAlignment="Center"
                TextAlignment="Center"
                TextWrapping="Wrap"/>
        </StackPanel>

        <!-- BOTTOM ACTION BAR
             Disconnect button — shown only when connected. -->
        <Border
            Grid.Row="5"
            Background="{StaticResource Surface0Brush}"
            Padding="16,12">

            <!-- Top border line -->
            <Border.Effect>
                <DropShadowEffect
                    Direction="90"
                    ShadowDepth="1"
                    BlurRadius="8"
                    Color="#FF000000"
                    Opacity="0.3"/>
            </Border.Effect>

            <Grid>
                <!-- Disconnect — only when connected -->
                <Button
                    Style="{StaticResource GhostButton}"
                    Content="Disconnect"
                    HorizontalAlignment="Stretch"
                    Command="{Binding DisconnectCommand}"
                    Visibility="{Binding IsConnected, Converter={StaticResource BoolToVis}}"/>

                <!-- Version info — when not connected -->
                <TextBlock
                    Text="v1.0.0"
                    Style="{StaticResource SecondaryText}"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Visibility="{Binding IsDisconnected, Converter={StaticResource BoolToVis}}"/>
            </Grid>
        </Border>

    </Grid>
</Window>
