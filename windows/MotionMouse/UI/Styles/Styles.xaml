<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
        Global WPF control styles for Motion Mouse.
        Applied via implicit styles (no x:Key) so they apply
        automatically to all matching controls in the app.
    -->

    <!-- Base window style — dark background, no default chrome -->
    <Style x:Key="MotionMouseWindow" TargetType="Window">
        <Setter Property="Background"       Value="{StaticResource Surface0Brush}"/>
        <Setter Property="Foreground"       Value="{StaticResource TextPrimaryBrush}"/>
        <Setter Property="FontFamily"       Value="Segoe UI"/>
        <Setter Property="FontSize"         Value="13"/>
        <Setter Property="MinWidth"         Value="360"/>
        <Setter Property="MinHeight"        Value="480"/>
        <Setter Property="ResizeMode"       Value="CanMinimize"/>
    </Style>

    <!-- Primary text -->
    <Style x:Key="PrimaryText" TargetType="TextBlock">
        <Setter Property="Foreground"   Value="{StaticResource TextPrimaryBrush}"/>
        <Setter Property="FontFamily"   Value="Segoe UI"/>
    </Style>

    <!-- Secondary / label text -->
    <Style x:Key="SecondaryText" TargetType="TextBlock">
        <Setter Property="Foreground"   Value="{StaticResource TextSecondaryBrush}"/>
        <Setter Property="FontSize"     Value="11"/>
        <Setter Property="FontFamily"   Value="Segoe UI"/>
    </Style>

    <!-- Section header — small caps style -->
    <Style x:Key="SectionHeader" TargetType="TextBlock">
        <Setter Property="Foreground"       Value="{StaticResource TextSecondaryBrush}"/>
        <Setter Property="FontSize"         Value="10"/>
        <Setter Property="FontWeight"       Value="SemiBold"/>
        <Setter Property="FontFamily"       Value="Segoe UI"/>
        <Setter Property="Margin"           Value="0,0,0,8"/>
    </Style>

    <!-- Card panel — elevated surface -->
    <Style x:Key="Card" TargetType="Border">
        <Setter Property="Background"       Value="{StaticResource Surface1Brush}"/>
        <Setter Property="CornerRadius"     Value="10"/>
        <Setter Property="Padding"          Value="16"/>
        <Setter Property="Margin"           Value="0,0,0,12"/>
    </Style>

    <!-- Primary action button — blue -->
    <Style x:Key="PrimaryButton" TargetType="Button">
        <Setter Property="Background"           Value="{StaticResource MotionBlueBrush}"/>
        <Setter Property="Foreground"           Value="White"/>
        <Setter Property="BorderThickness"      Value="0"/>
        <Setter Property="Padding"              Value="20,10"/>
        <Setter Property="FontFamily"           Value="Segoe UI"/>
        <Setter Property="FontWeight"           Value="SemiBold"/>
        <Setter Property="FontSize"             Value="13"/>
        <Setter Property="Cursor"               Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border
                        Background="{TemplateBinding Background}"
                        CornerRadius="8"
                        Padding="{TemplateBinding Padding}">
                        <ContentPresenter
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background"
                                    Value="{StaticResource MotionBlueDimBrush}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter Property="Opacity" Value="0.8"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.4"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Ghost button — outlined, no fill -->
    <Style x:Key="GhostButton" TargetType="Button">
        <Setter Property="Background"       Value="Transparent"/>
        <Setter Property="Foreground"       Value="{StaticResource TextSecondaryBrush}"/>
        <Setter Property="BorderBrush"      Value="{StaticResource Surface3Brush}"/>
        <Setter Property="BorderThickness"  Value="1"/>
        <Setter Property="Padding"          Value="16,8"/>
        <Setter Property="FontFamily"       Value="Segoe UI"/>
        <Setter Property="Cursor"           Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="6"
                        Padding="{TemplateBinding Padding}">
                        <ContentPresenter
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background"
                                    Value="{StaticResource Surface2Brush}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter Property="Opacity" Value="0.7"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Slider style — dark track, blue thumb -->
    <Style TargetType="Slider">
        <Setter Property="Foreground" Value="{StaticResource MotionBlueBrush}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Slider">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto" MinHeight="{TemplateBinding MinHeight}"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Track x:Name="PART_Track" Grid.Row="1">
                            <Track.DecreaseRepeatButton>
                                <RepeatButton
                                    Style="{x:Null}"
                                    Background="{StaticResource MotionBlueBrush}"
                                    Height="3"
                                    BorderThickness="0"
                                    IsTabStop="False"/>
                            </Track.DecreaseRepeatButton>
                            <Track.IncreaseRepeatButton>
                                <RepeatButton
                                    Style="{x:Null}"
                                    Background="{StaticResource Surface3Brush}"
                                    Height="3"
                                    BorderThickness="0"
                                    IsTabStop="False"/>
                            </Track.IncreaseRepeatButton>
                            <Track.Thumb>
                                <Thumb Width="16" Height="16">
                                    <Thumb.Template>
                                        <ControlTemplate TargetType="Thumb">
                                            <Ellipse
                                                Fill="{StaticResource MotionBlueBrush}"
                                                Width="16"
                                                Height="16"/>
                                        </ControlTemplate>
                                    </Thumb.Template>
                                </Thumb>
                            </Track.Thumb>
                        </Track>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- CheckBox style — dark themed -->
    <Style TargetType="CheckBox">
        <Setter Property="Foreground"   Value="{StaticResource TextPrimaryBrush}"/>
        <Setter Property="FontFamily"   Value="Segoe UI"/>
        <Setter Property="Cursor"       Value="Hand"/>
    </Style>

    <!-- ScrollBar — minimal dark scrollbar -->
    <Style TargetType="ScrollBar">
        <Setter Property="Background"   Value="Transparent"/>
        <Setter Property="Width"        Value="6"/>
        <Setter Property="Opacity"      Value="0.5"/>
    </Style>

</ResourceDictionary>
